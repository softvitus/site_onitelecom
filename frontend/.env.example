# Frontend Environment Variables
# ═════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and customize

# ─────────────────────────────────────────────────────────────────────────────
# API CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────

# API base URL - onde a API REST está rodando
# Development: http://localhost:5000 (docker) ou http://localhost:3000 (npm start)
# Production: https://api.onitelecom.com.br
REACT_APP_API_URL=http://localhost:5000/api/v1

# ─────────────────────────────────────────────────────────────────────────────
# ENVIRONMENT
# ─────────────────────────────────────────────────────────────────────────────

# Environment: development, staging, production
REACT_APP_ENVIRONMENT=development

# App version (definido automaticamente)
REACT_APP_VERSION=1.0.0

# ─────────────────────────────────────────────────────────────────────────────
# FEATURES
# ─────────────────────────────────────────────────────────────────────────────

# Enable debug mode (mostra logs no console)
REACT_APP_DEBUG=true

# Enable analytics
REACT_APP_ANALYTICS_ENABLED=false

# Enable service workers (PWA)
REACT_APP_SERVICE_WORKER=false

# ─────────────────────────────────────────────────────────────────────────────
# EXTERNAL SERVICES
# ─────────────────────────────────────────────────────────────────────────────

# Google Analytics ID (opcional)
REACT_APP_GOOGLE_ANALYTICS_ID=

# Sentry DSN (error tracking)
REACT_APP_SENTRY_DSN=

# MapBox token (se usar mapas)
REACT_APP_MAPBOX_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# BUILD
# ─────────────────────────────────────────────────────────────────────────────

# Public path (para deployments em subpaths)
PUBLIC_URL=/

# Port (development server)
PORT=3000

# Browser auto-open on dev
BROWSER=false
