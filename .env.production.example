# Backend Production Configuration
PORT=5000
NODE_ENV=production

# Database
DB_HOST=postgres.servidor.com.br
DB_PORT=5432
DB_NAME=site_oni
DB_USER=site_oni_user
DB_PASSWORD=MUDE_ISSO_SUA_SENHA_FORTE
DB_DIALECT=postgres

# JWT
JWT_SECRET=MUDE_ISSO_SUA_CHAVE_JWT_MUITO_LONGA
JWT_EXPIRE=24h

# Application
API_URL=http://localhost:5000
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=500

# CORS
CORS_ORIGIN=https://seu-dominio.com.br

# Email (optional)
SMTP_HOST=smtp.seuservidor.com
SMTP_PORT=587
SMTP_USER=noreply@seu-dominio.com.br
SMTP_PASSWORD=sua_senha_email

# AWS S3 (optional, para imagens)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=sua_chave
AWS_SECRET_ACCESS_KEY=sua_chave_secreta
S3_BUCKET=seu-bucket
