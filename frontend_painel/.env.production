# 🌐 Variáveis de Ambiente - Produção

# API Backend (localhost:5000 para Docker, ou domínio em produção)
VITE_API_URL=http://localhost:5000/api/v1
VITE_API_TIMEOUT=15000

# Ambiente
VITE_APP_ENV=production
VITE_DEBUG=false

# Paginação
VITE_PAGE_SIZE=25

# Notificações
VITE_TOAST_DURATION=2000

# Temas
VITE_THEME=light
