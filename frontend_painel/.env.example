# Frontend Painel (Painel Administrativo) Environment Variables
# ═════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and customize

# ─────────────────────────────────────────────────────────────────────────────
# API CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────

# API base URL - onde a API REST está rodando
# Development: http://localhost:5000 (docker) ou http://localhost:3000 (npm start)
# Production: https://api.onitelecom.com.br
VITE_API_URL=http://localhost:5000/api/v1

# ─────────────────────────────────────────────────────────────────────────────
# ENVIRONMENT
# ─────────────────────────────────────────────────────────────────────────────

# Environment: development, staging, production
VITE_ENVIRONMENT=development

# App version
VITE_VERSION=1.0.0

# App name
VITE_APP_NAME=ONI Telecom - Painel Administrativo

# ─────────────────────────────────────────────────────────────────────────────
# FEATURES
# ─────────────────────────────────────────────────────────────────────────────

# Enable debug mode
VITE_DEBUG=true

# Enable analytics
VITE_ANALYTICS_ENABLED=false

# ─────────────────────────────────────────────────────────────────────────────
# EXTERNAL SERVICES
# ─────────────────────────────────────────────────────────────────────────────

# Sentry DSN (error tracking)
VITE_SENTRY_DSN=

# ─────────────────────────────────────────────────────────────────────────────
# BUILD
# ─────────────────────────────────────────────────────────────────────────────

# Base path (para deployments em subpaths)
VITE_BASE=/

# Build output directory
VITE_BUILD_DIR=dist

# Port (development server)
VITE_PORT=5173
