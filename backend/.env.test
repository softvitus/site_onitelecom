# ================================
# Test Environment Configuration
# ================================
NODE_ENV=test

# ================================
# Database Configuration - Tests
# ================================
DB_TEST_HOST=localhost
DB_TEST_PORT=5432
DB_TEST_NAME=site_oni_02
DB_TEST_USER=postgres
DB_TEST_PASSWORD="root1234"
DB_DIALECT=postgres

# ================================
# JWT Configuration
# ================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production-12345
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-12345
JWT_REFRESH_EXPIRES_IN=30d

# ================================
# API Configuration
# ================================
API_BASE_URL=http://localhost:3000
API_VERSION=v1

# ================================
# CORS Configuration
# ================================
CORS_ORIGIN=http://localhost:3001,http://localhost:3000,http://localhost:3002,http://localhost:3003

# ================================
# Logging Configuration
# ================================
LOG_LEVEL=error

# ================================
# Upload Configuration
# ================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# ================================
# Cache Configuration (Redis)
# ================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ================================
# Rate Limiting
# ================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
