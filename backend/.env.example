# Backend Environment Variables
# ═════════════════════════════════════════════════════════════════════════════
# Copy this file to .env.production e .env.development e customize

# ─────────────────────────────────────────────────────────────────────────────
# SERVER CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────

# Node environment: development, test, production
NODE_ENV=development

# Server port (3000 = development, 5000 = docker)
PORT=3000

# Server host (0.0.0.0 = docker accessible from outside)
HOST=localhost

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────

# Database dialect: postgres, mysql, sqlite3
DB_DIALECT=postgres

# Database host
DB_HOST=localhost

# Database port
DB_PORT=5432

# Database name
DB_NAME=site_oni

# Database user
DB_USER=postgres

# Database password
DB_PASSWORD=postgres

# Database connection pool
DB_POOL_MIN=2
DB_POOL_MAX=5

# ─────────────────────────────────────────────────────────────────────────────
# AUTHENTICATION
# ─────────────────────────────────────────────────────────────────────────────

# JWT secret key - MUDE EM PRODUÇÃO! Use uma string longa e aleatória
JWT_SECRET=sua-chave-secreta-super-segura-aqui-mude-em-producao

# JWT expiration time (1h, 7d, etc)
JWT_EXPIRATION=7d

# ─────────────────────────────────────────────────────────────────────────────
# API CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────

# API URL base (usado em emails, logs, etc)
API_URL=http://localhost:3000

# API version (para versionamento de endpoints)
API_VERSION=v1

# CORS origins (separados por vírgula)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5000

# ─────────────────────────────────────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────────────────────────────────────

# Log level: error, warn, info, debug, trace
LOG_LEVEL=info

# Log format: json, text
LOG_FORMAT=text

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL (Nodemailer)
# ─────────────────────────────────────────────────────────────────────────────

# SMTP host
SMTP_HOST=smtp.gmail.com

# SMTP port
SMTP_PORT=587

# SMTP user
SMTP_USER=seu-email@gmail.com

# SMTP password (use app password para Gmail)
SMTP_PASSWORD=sua-senha-app

# From email
MAIL_FROM=noreply@onitelecom.com.br

# ─────────────────────────────────────────────────────────────────────────────
# EXTERNAL SERVICES
# ─────────────────────────────────────────────────────────────────────────────

# Geocoding API (para localização)
GEOCODE_API_URL=https://geocoding-api.open-meteo.com/v1/reverse

# ─────────────────────────────────────────────────────────────────────────────
# MONITORING & ALERTING
# ─────────────────────────────────────────────────────────────────────────────

# Sentry DSN (error tracking)
SENTRY_DSN=

# Health check interval (ms)
HEALTH_CHECK_INTERVAL=30000

# ─────────────────────────────────────────────────────────────────────────────
# DOCKER SPECIFIC
# ─────────────────────────────────────────────────────────────────────────────

# Backend health check (para docker healthcheck)
BACKEND_HEALTH_INTERVAL=30s
BACKEND_HEALTH_TIMEOUT=10s
BACKEND_HEALTH_RETRIES=3
BACKEND_HEALTH_START=40s

# Restart policy
BACKEND_RESTART=unless-stopped

# CPU/Memory limits
BACKEND_CPUS_LIMIT=4
BACKEND_MEMORY_LIMIT=2G
BACKEND_CPUS_RESERVE=1
BACKEND_MEMORY_RESERVE=512M
