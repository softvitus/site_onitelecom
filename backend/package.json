{
  "name": "site-oni-backend",
  "version": "1.0.0",
  "description": "Backend API para sistema white-label multi-tenant Site Oni",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "cross-env NODE_ENV=development nodemon server.js",
    "migrate": "cross-env NODE_ENV=development sequelize-cli db:migrate",
    "migrate:prod": "cross-env NODE_ENV=production sequelize-cli db:migrate",
    "migrate:undo": "cross-env NODE_ENV=development sequelize-cli db:migrate:undo",
    "migrate:undo:all": "cross-env NODE_ENV=development sequelize-cli db:migrate:undo:all",
    "migrate:undo:all:prod": "cross-env NODE_ENV=production sequelize-cli db:migrate:undo:all",
    "seed": "cross-env NODE_ENV=development sequelize-cli db:seed:all",
    "seed:prod": "cross-env NODE_ENV=production sequelize-cli db:seed:all",
    "seed:undo": "cross-env NODE_ENV=development sequelize-cli db:seed:undo:all",
    "seed:undo:prod": "cross-env NODE_ENV=production sequelize-cli db:seed:undo:all",
    "db:clean": "cross-env NODE_ENV=development sequelize-cli db:migrate:undo:all && cross-env NODE_ENV=development sequelize-cli db:seed:undo:all",
    "db:reset": "npm run migrate:undo:all && npm run migrate && npm run seed",
    "db:reset:prod": "npm run migrate:undo:all:prod && npm run migrate:prod && npm run seed:prod",
    "db:reset:test": "cross-env NODE_ENV=test npm run db:reset",
    "test": "cross-env NODE_ENV=test jest --passWithNoTests",
    "test:performance": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest src/__tests__/performance --verbose",
    "test:security": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest src/__tests__/security --verbose",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write \"src/**/*.js\""
  },
  "envConfig": {
    "development": ".env",
    "production": ".env.production",
    "test": ".env.test"
  },
  "keywords": [
    "site-oni",
    "white-label",
    "multi-tenant",
    "api",
    "express"
  ],
  "author": "Site Oni Team",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.1",
    "helmet": "^8.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "node-cache": "^5.1.2",
    "pg": "^8.10.0",
    "sequelize": "^6.35.2",
    "sharp": "^0.34.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "babel-jest": "^30.2.0",
    "cross-env": "^10.1.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.0",
    "sequelize-cli": "^6.6.2",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
